# FRONTIER Environment Variables Template
# Copy to .env and fill with your actual values
# DO NOT commit actual secrets to git

# ============= DATABASE =============
# Neon, Railway PostgreSQL, or any Postgres connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ============= SESSION =============
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Also signs admin session + 2FA tokens (server/adminAuth.ts).
SESSION_SECRET=your-session-secret-here

# ============= ADMIN LOGIN + SMS 2FA =============
# The admin dashboard uses a real login: username + password + SMS 2FA
# (server/adminAuth.ts). Seed the first admin user once (after `pnpm db:push`):
#   tsx server/scripts/seedAdmin.ts <username> <password> <phoneE164>
# Admin session lifetime in hours (default 8).
ADMIN_SESSION_TTL_HOURS=8
#
# Twilio — you create this account at https://www.twilio.com (free trial works).
# Set all three to send real SMS codes. If unset: in DEV the code is logged to the
# server console (so you can test without a provider); in PROD login fails loudly.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
#
# Legacy static gate for machine/automation callers (e.g. veritas). Optional and
# NOT a human login — the username+password+2FA flow above is preferred. If set,
# it also works as a fallback `x-admin-key` header on admin endpoints.
# ADMIN_KEY=

# ============= ALGORAND BLOCKCHAIN =============
# Network: "mainnet" or "testnet"
ALGORAND_NETWORK=testnet

# Admin mnemonic (25-word phrase) - STORE IN SECURE VAULT, NEVER IN CODE
# This account performs on-chain operations (ASA creation, transfers, etc.)
ALGORAND_ADMIN_MNEMONIC=word1 word2 word3 ... word25
ALGORAND_ADMIN_ADDRESS=YOUR_ADMIN_ADDRESS_HERE

# Algorand RPC endpoints (optional, defaults to testnet)
ALGOD_URL=https://testnet-api.algonode.cloud
INDEXER_URL=https://testnet-idx.algonode.cloud

# ============= REDIS (Upstash) =============
# For world events, game state caching, and session storage
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ============= FRONTEND =============
# URL of the client app (for CORS — set to your Vercel domain in production)
CLIENT_ORIGIN=http://localhost:3000

# Public base URL for generated content (NFT metadata, static assets)
PUBLIC_BASE_URL=http://localhost:5000

# ============= CLIENT (VITE) ENVIRONMENT VARIABLES =============
# These are embedded at build time by Vite and exposed to the browser.
# Only set these when deploying the SPA (client/) separately from the backend.
# Leave blank for local development — the Vite proxy handles /api/* → :5000.

# Backend HTTP origin for API calls (no trailing slash)
# Example: https://frontier-api.onrender.com
VITE_API_URL=

# Backend WebSocket origin for real-time updates (no trailing slash)
# Example: https://frontier-api.onrender.com  (wss:// is inferred from https://)
VITE_WS_URL=

# Local testing only: boot straight into the 3D globe, skipping the landing
# page and wallet-connect gate. Dev builds only (ignored in production).
# Leave unset/false for the normal landing + wallet flow.
VITE_TEST_GLOBE=false

# ============= DEPLOYMENT =============
NODE_ENV=development
PORT=3000

# ============= OPTIONAL FEATURES =============
# AI_ENABLED: "true" to enable AI faction turns, "false" or unset to disable
AI_ENABLED=false

# FORCE_NEW_ASA: "true" to create a new Algorand Standard Asset on startup
FORCE_NEW_ASA=false

# FORCE_NEW_FRONTIER_ASA: set to "true" to re-mint the FRONTIER ASA with clawback role on next startup.
# The new ASA will have clawback=admin so fireBurn/clawbackFrontierAsa succeed on-chain.
# IMPORTANT: flip back to "false" after restart to prevent re-minting on subsequent restarts.
# FORCE_NEW_FRONTIER_ASA=true
FORCE_NEW_FRONTIER_ASA=false

# ============= NOTES =============
# Production Checklist:
# - Change ALGORAND_NETWORK from "testnet" to "mainnet"
# - Rotate SESSION_SECRET (don't reuse testnet value)
# - Update ALGORAND_ADMIN_MNEMONIC with production key
# - Set NODE_ENV=production (suppresses console logs)
# - Update CLIENT_ORIGIN to production domain
# - Update PUBLIC_BASE_URL to production domain
# - Verify UPSTASH_REDIS credentials for production instance
