# Aether's Journey — build-time config (Vite). Copy to `.env` and adjust.
# Only VITE_-prefixed vars are exposed to the browser bundle.

# Where "Continue to FRONTIER-AL" sends the player after the on-chain claim.
# Point this at the deployed main game for a given environment.
VITE_FRONTIER_AL_URL=https://frontieralgo.pages.dev

# --- Algorand (TESTNET ONLY for the prologue claim) ------------------------
# Network label shown in the claim UI (display only).
VITE_ALGORAND_NETWORK=testnet
# Algod endpoint used to submit the claim's transactions.
VITE_ALGOD_URL=https://testnet-api.algonode.cloud
# Algod API token (AlgoNode needs none; leave blank).
VITE_ALGOD_TOKEN=
